{
    "name": "nepal360/filament-cms-pro",
    "description": "An enterprise-grade WordPress-class CMS plugin for Laravel and Filament v5 with non-intrusive server-side analytics.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "nepal360",
            "email": "info@nepal360.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "filament/filament": "^5.0",
        "spatie/laravel-permission": "^6.0|^7.0|^8.0",
        "ezyang/htmlpurifier": "^4.16|^4.17|^4.18|^4.19"
    },
    "require-dev": {
        "pestphp/pest": "^2.0|^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Nepal360\\FilamentCmsPro\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nepal360\\FilamentCmsPro\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nepal360\\FilamentCmsPro\\FilamentCmsProServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
